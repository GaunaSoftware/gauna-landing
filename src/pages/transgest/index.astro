---
import BaseLayout from '@layouts/BaseLayout.astro';
import LogoTransGest from '@components/LogoTransGest.astro';

export const prerender = true;

const productStatus = [
  {
    name: 'Gestión de servicios',
    status: 'Terminado',
    description: 'Control de servicios, cargas, estados operativos y seguimiento diario desde una sola plataforma.',
  },
  {
    name: 'Clientes y vehículos',
    status: 'Terminado',
    description: 'Base centralizada para gestionar clientes, vehículos, conductores y datos principales de la empresa.',
  },
  {
    name: 'Expediente digital por transporte',
    status: 'En desarrollo avanzado',
    description: 'Cada servicio como expediente completo: operativo, documental, trazable y administrativo.',
  },
  {
    name: 'Documentación DeCA-ready',
    status: 'En desarrollo avanzado',
    description: 'Estructuración de datos y documentos para preparar cada transporte con mayor trazabilidad documental.',
  },
  {
    name: 'eCMR',
    status: 'En desarrollo avanzado',
    description: 'Evolución hacia carta de porte digital y documentación asociada directamente al servicio.',
  },
  {
    name: 'Facturación',
    status: 'Terminado',
    description: 'Gestión administrativa y facturación vinculada a servicios, clientes y documentación del transporte.',
  },
  {
    name: 'App conductor',
    status: 'Terminado',
    description: 'Acceso para conductores, gestión operativa y comunicación más directa entre carretera y oficina.',
  },
  {
    name: 'Integraciones / API',
    status: 'En fase avanzada',
    description: 'Arquitectura preparada para conectar TransGest con sistemas externos, clientes, proveedores y futuras plataformas.',
  },
  {
    name: 'Fichajes',
    status: 'En fase avanzada',
    description: 'Control de presencia y registro horario conectado con la operativa diaria de la empresa.',
  },
  {
    name: 'Programa de contabilidad',
    status: 'En desarrollo',
    description: 'Módulo contable conectado con facturación, administración y actividad real del transporte.',
  },
  {
    name: 'Portal de cliente',
    status: 'Terminado',
    description: 'Acceso para clientes con información, documentación y seguimiento de servicios.',
  },
];

const statusStyles: Record<string, string> = {
  'Terminado': 'bg-emerald-100 text-emerald-800 border-emerald-200',
  'En desarrollo avanzado': 'bg-teal-100 text-teal-800 border-teal-200',
  'En fase avanzada': 'bg-blue-100 text-blue-800 border-blue-200',
  'En desarrollo': 'bg-amber-100 text-amber-800 border-amber-200',
};

const problems = [
  {
    title: 'Demasiada información dispersa',
    description: 'Cargas en Excel, documentos por WhatsApp, facturas en otro programa y datos que se pierden entre tráfico, administración y conductores.',
  },
  {
    title: 'Los TMS tradicionales se han quedado rígidos',
    description: 'Muchas soluciones son potentes, pero complejas, poco intuitivas y alejadas de cómo trabaja realmente una empresa de transporte en el día a día.',
  },
  {
    title: 'La documentación pesa cada vez más',
    description: 'DeCA, eCMR, trazabilidad, expedientes digitales, residuos, ADR e integraciones futuras obligan a trabajar con datos mejor organizados.',
  },
  {
    title: 'Falta visión global por servicio',
    description: 'Una empresa necesita saber rápido qué servicio está listo, qué documento falta, qué conductor está asignado y qué se puede facturar.',
  },
];

const modules = [
  {
    title: 'Gestión de servicios y cargas',
    description: 'Organiza cada transporte con cliente, origen, destino, vehículo, conductor, estado operativo y documentación asociada.',
  },
  {
    title: 'Expediente digital por transporte',
    description: 'Convierte cada servicio en un expediente operativo, documental, administrativo y trazable.',
  },
  {
    title: 'Clientes, vehículos y conductores',
    description: 'Centraliza los datos principales de la empresa y evita duplicidades, errores y búsquedas innecesarias.',
  },
  {
    title: 'Documentación y cumplimiento',
    description: 'Prepara la documentación vinculada al servicio con una estructura pensada para DeCA, eCMR y futuras integraciones.',
  },
  {
    title: 'Facturación y administración',
    description: 'Conecta servicios realizados con facturación, estados administrativos y control interno.',
  },
  {
    title: 'App conductor',
    description: 'Facilita la comunicación entre oficina y carretera, el acceso a servicios y la gestión operativa del conductor.',
  },
  {
    title: 'Portal de cliente',
    description: 'Ofrece a tus clientes acceso a información y documentación sin depender de llamadas, correos o mensajes sueltos.',
  },
  {
    title: 'Integraciones y API',
    description: 'Arquitectura preparada para conectar con otros sistemas y evolucionar con las necesidades del sector.',
  },
];

const legalFeatures = [
  {
    title: 'DeCA-ready',
    description: 'Diseñado para estructurar datos y documentación del transporte con trazabilidad y preparación digital.',
  },
  {
    title: 'eCMR',
    description: 'Orientado a trabajar con carta de porte digital y documentación asociada al servicio.',
  },
  {
    title: 'eFTI-ready',
    description: 'Arquitectura pensada para datos estructurados e integraciones futuras con plataformas certificadas cuando corresponda.',
  },
  {
    title: 'DIWASS-ready',
    description: 'Preparado conceptualmente para gestionar documentación y datos relacionados con traslados de residuos.',
  },
];

const benefits = [
  'Menos papel y menos documentos perdidos.',
  'Más control sobre cada servicio.',
  'Documentación vinculada al transporte.',
  'Mejor comunicación entre oficina y conductor.',
  'Facturación más conectada con la operativa.',
  'Clientes con acceso más profesional a su información.',
  'Datos preparados para integraciones futuras.',
  'Una imagen más moderna frente a clientes y colaboradores.',
];
---

<BaseLayout
  title="TransGest | TMS moderno para empresas de transporte"
  description="TransGest es un TMS moderno para empresas de transporte que centraliza servicios, clientes, vehículos, conductores, documentación, facturación, portal de cliente e integraciones en una sola plataforma."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-20 md:pb-28 overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-900/50 via-slate-950 to-slate-950 pointer-events-none"></div>

    <div class="container-g relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/10 rounded-full mb-8">
          <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
          <span class="text-sm font-medium text-teal-50">TMS moderno creado desde dentro del sector transporte</span>
        </div>

        <div class="flex justify-center mb-8">
          <LogoTransGest class="h-12 md:h-14 w-auto" />
        </div>

        <h1 class="text-display-md md:text-display-lg lg:text-display-xl font-medium leading-[1.05]">
          El TMS que viene a cambiar la forma de gestionar el transporte.
        </h1>

        <p class="text-lg md:text-xl text-slate-300 mt-8 max-w-3xl mx-auto leading-relaxed">
          TransGest centraliza servicios, cargas, clientes, conductores, vehículos, documentación, facturación, fichajes, portal de cliente e integraciones en una plataforma moderna, clara y pensada para la operativa real del sector.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contacto/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber-500 text-slate-900 font-medium rounded-lg hover:bg-amber-400 transition-colors">
            Solicitar información
          </a>
          <a href="https://app.gauna.es" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-medium rounded-lg hover:bg-white/15 border border-white/15 transition-colors">
            Acceso clientes
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEMAS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">El problema</span>
        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          El transporte necesita software más claro, más conectado y más realista.
        </h2>
        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          Muchas empresas siguen trabajando con información repartida entre hojas de cálculo, correos, WhatsApp, carpetas, programas sueltos y procesos manuales. TransGest nace para ordenar todo eso.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {problems.map((problem) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-slate-900">
              {problem.title}
            </h3>
            <p class="text-slate-600 mt-3 leading-relaxed">
              {problem.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUCIÓN -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <span class="eyebrow">La solución</span>
        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Cada servicio como expediente digital completo.
        </h2>
        <p class="text-lg text-slate-600 mt-5 max-w-3xl mx-auto leading-relaxed">
          TransGest no nace solo para apuntar cargas. El objetivo es que cada transporte tenga su propio expediente: datos operativos, conductor, vehículo, documentos, estados, validaciones, facturación, cliente y trazabilidad.
        </p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">1. Servicio</div>
            <p class="text-sm text-slate-600 mt-2">Origen, destino, cliente, fechas, carga y estado operativo.</p>
          </div>
          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">2. Recursos</div>
            <p class="text-sm text-slate-600 mt-2">Conductor, vehículo, documentación y datos vinculados.</p>
          </div>
          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">3. Documentos</div>
            <p class="text-sm text-slate-600 mt-2">DeCA-ready, eCMR, PDFs, evidencias e historial.</p>
          </div>
          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">4. Administración</div>
            <p class="text-sm text-slate-600 mt-2">Facturación, portal cliente, contabilidad e integraciones.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MÓDULOS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">Módulos principales</span>
        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Todo conectado en una sola plataforma.
        </h2>
        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          Una empresa de transporte no necesita más islas de información. Necesita una herramienta donde tráfico, administración, conductores y clientes trabajen sobre la misma base.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {modules.map((mod) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-5 hover:bg-white hover:border-teal-300 hover:shadow-sm transition-all">
            <h3 class="text-base font-semibold text-slate-900">
              {mod.title}
            </h3>
            <p class="text-sm text-slate-600 mt-3 leading-relaxed">
              {mod.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ESTADO DEL PRODUCTO -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <span class="eyebrow">Estado del producto</span>
        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Una plataforma avanzada para cubrir la operativa completa del transporte.
        </h2>
        <p class="text-lg text-slate-600 mt-5 max-w-3xl mx-auto leading-relaxed">
          TransGest avanza con una visión clara: centralizar la gestión operativa, documental, administrativa y comercial de una empresa de transporte en un único entorno.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {productStatus.map((item) => (
          <article class="bg-white border border-slate-200 rounded-2xl p-5 hover:border-teal-300 hover:shadow-sm transition-all">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-base font-semibold text-slate-900 leading-snug">
                {item.name}
              </h3>
              <span class={`shrink-0 text-[10px] font-semibold tracking-wide uppercase px-2.5 py-1 rounded-full border ${statusStyles[item.status] || 'bg-slate-100 text-slate-700 border-slate-200'}`}>
                {item.status}
              </span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">
              {item.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CUMPLIMIENTO DOCUMENTAL -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">Documentación y normativa</span>
        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Preparado para la digitalización documental del transporte.
        </h2>
        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          TransGest está diseñado para trabajar con datos estructurados, documentación vinculada al servicio y una arquitectura orientada a DeCA, eCMR, eFTI y DIWASS, con el objetivo de avanzar hacia las certificaciones e integraciones necesarias del sector.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {legalFeatures.map((feature) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-5">
            <h3 class="text-base font-semibold text-slate-900">
              {feature.title}
            </h3>
            <p class="text-sm text-slate-600 mt-3 leading-relaxed">
              {feature.description}
            </p>
          </article>
        ))}
      </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="py-16 md:py-20 bg-slate-950 text-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow text-teal-300">Beneficios</span>
        <h2 class="text-display-sm font-medium mt-3 leading-tight">
          Menos papel, menos errores y más control.
        </h2>
        <p class="text-lg text-slate-300 mt-5 leading-relaxed">
          TransGest está pensado para empresas que quieren modernizar su gestión sin perder de vista la realidad del transporte.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {benefits.map((benefit) => (
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="mt-1 w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
            <p class="text-slate-200 leading-relaxed">
              {benefit}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 md:py-24 bg-teal-900 text-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-sm md:text-display-md font-medium leading-tight">
          ¿Quieres ver cómo TransGest puede encajar en tu empresa?
        </h2>
        <p class="text-lg md:text-xl text-teal-50 mt-6 leading-relaxed">
          Hablemos de tu operativa actual: servicios, documentos, conductores, vehículos, facturación, clientes e integraciones. Te mostraremos cómo TransGest puede ayudarte a ordenar y modernizar tu gestión.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contacto/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber-500 text-slate-900 font-medium rounded-lg hover:bg-amber-400 transition-colors">
            Solicitar información
          </a>
          <a href="https://app.gauna.es" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-teal-800 text-white font-medium rounded-lg hover:bg-teal-700 border border-teal-700 transition-colors">
            Acceso clientes
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
