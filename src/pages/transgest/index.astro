
---
import BaseLayout from '@layouts/BaseLayout.astro';

export const prerender = true;

const pageTitle = 'TransGest | TMS y software de gestión para empresas de transporte';
const pageDescription =
  'TransGest es un TMS moderno para empresas de transporte. Centraliza servicios, cargas, clientes, vehículos, conductores, documentación digital, facturación, portal cliente, app conductor e integraciones.';

const problems = [
  {
    title: 'Información dispersa entre demasiadas herramientas',
    description:
      'Servicios en Excel, documentos por WhatsApp, facturas en otro programa y datos que se pierden entre tráfico, administración, conductores y clientes.',
  },
  {
    title: 'TMS tradicionales demasiado rígidos',
    description:
      'Muchas soluciones son potentes, pero complejas, poco intuitivas o alejadas de cómo trabaja realmente una empresa de transporte en el día a día.',
  },
  {
    title: 'La documentación pesa cada vez más',
    description:
      'DeCA, eCMR, trazabilidad documental, residuos, ADR, SANDACH e integraciones futuras exigen trabajar con datos mejor organizados.',
  },
  {
    title: 'Falta visión global por servicio',
    description:
      'Una empresa necesita saber rápido qué servicio está listo, qué documento falta, qué conductor está asignado, qué cliente debe recibir información y qué puede facturarse.',
  },
];

const modules = [
  {
    title: 'Gestión de servicios y cargas',
    description:
      'Organiza cada transporte con cliente, origen, destino, vehículo, conductor, estado operativo y documentación asociada.',
  },
  {
    title: 'Expediente digital por transporte',
    description:
      'Convierte cada servicio en un expediente operativo, documental, administrativo y trazable.',
  },
  {
    title: 'Clientes, vehículos y conductores',
    description:
      'Centraliza los datos principales de la empresa y evita duplicidades, errores y búsquedas innecesarias.',
  },
  {
    title: 'Documentación y cumplimiento',
    description:
      'Prepara la documentación vinculada al servicio con una estructura pensada para DeCA, eCMR, eFTI y DIWASS.',
  },
  {
    title: 'Facturación y administración',
    description:
      'Conecta servicios realizados con facturación, estados administrativos y control interno.',
  },
  {
    title: 'App conductor',
    description:
      'Facilita la comunicación entre oficina y carretera, el acceso a servicios y la gestión operativa del conductor.',
  },
  {
    title: 'Portal de cliente',
    description:
      'Ofrece a tus clientes acceso a información y documentación sin depender de llamadas, correos o mensajes sueltos.',
  },
  {
    title: 'Integraciones y API',
    description:
      'Arquitectura preparada para conectar con otros sistemas y evolucionar con las necesidades del sector.',
  },
];

const productStatus = [
  {
    name: 'Gestión de servicios',
    status: 'Terminado',
    description:
      'Control de servicios, cargas, estados operativos y seguimiento diario desde una sola plataforma.',
  },
  {
    name: 'Clientes y vehículos',
    status: 'Terminado',
    description:
      'Base centralizada para gestionar clientes, vehículos, conductores y datos principales de la empresa.',
  },
  {
    name: 'Expediente digital por transporte',
    status: 'En desarrollo avanzado',
    description:
      'Cada servicio como expediente completo: operativo, documental, trazable y administrativo.',
  },
  {
    name: 'Documentación DeCA-ready',
    status: 'En desarrollo avanzado',
    description:
      'Estructuración de datos y documentos para preparar cada transporte con mayor trazabilidad documental.',
  },
  {
    name: 'eCMR',
    status: 'En desarrollo avanzado',
    description:
      'Evolución hacia carta de porte digital y documentación asociada directamente al servicio.',
  },
  {
    name: 'Facturación',
    status: 'Terminado',
    description:
      'Gestión administrativa y facturación vinculada a servicios, clientes y documentación del transporte.',
  },
  {
    name: 'App conductor',
    status: 'Terminado',
    description:
      'Acceso para conductores, gestión operativa y comunicación más directa entre carretera y oficina.',
  },
  {
    name: 'Integraciones / API',
    status: 'En fase avanzada',
    description:
      'Arquitectura preparada para conectar TransGest con sistemas externos, clientes, proveedores y futuras plataformas.',
  },
  {
    name: 'Fichajes',
    status: 'En fase avanzada',
    description:
      'Control de presencia y registro horario conectado con la operativa diaria de la empresa.',
  },
  {
    name: 'Programa de contabilidad',
    status: 'En desarrollo',
    description:
      'Módulo contable conectado con facturación, administración y actividad real del transporte.',
  },
  {
    name: 'Portal de cliente',
    status: 'Terminado',
    description:
      'Acceso para clientes con información, documentación y seguimiento de servicios.',
  },
];

const statusStyles: Record<string, string> = {
  Terminado: 'bg-emerald-100 text-emerald-800 border-emerald-200',
  'En desarrollo avanzado': 'bg-teal-100 text-teal-800 border-teal-200',
  'En fase avanzada': 'bg-blue-100 text-blue-800 border-blue-200',
  'En desarrollo': 'bg-amber-100 text-amber-800 border-amber-200',
};

const legalFeatures = [
  {
    title: 'DeCA',
    description:
      'Orientado a estructurar los datos y documentos necesarios para el Documento electrónico de Control Administrativo.',
  },
  {
    title: 'eCMR',
    description:
      'Preparado para trabajar con carta de porte digital y documentación vinculada al servicio.',
  },
  {
    title: 'eFTI',
    description:
      'Arquitectura orientada a datos estructurados, interoperabilidad e integraciones vinculadas al marco eFTI.',
  },
  {
    title: 'DIWASS',
    description:
      'Preparado para evolucionar hacia la gestión documental y de datos relacionada con traslados de residuos y sistemas sectoriales.',
  },
];

const benefits = [
  'Menos papel y menos documentos perdidos.',
  'Más control sobre cada servicio.',
  'Documentación vinculada al transporte.',
  'Mejor comunicación entre oficina y conductor.',
  'Facturación conectada con la operativa real.',
  'Clientes con acceso más profesional a su información.',
  'Datos preparados para integraciones futuras.',
  'Una imagen más moderna frente a clientes y colaboradores.',
];

const faqs = [
  {
    question: '¿Qué es TransGest?',
    answer:
      'TransGest es un TMS moderno para empresas de transporte. Centraliza servicios, cargas, clientes, vehículos, conductores, documentación, facturación, portal cliente, app conductor e integraciones.',
  },
  {
    question: '¿Para qué tipo de empresas está pensado TransGest?',
    answer:
      'Está pensado para empresas de transporte por carretera, operadores logísticos, pymes de transporte, equipos de tráfico, administración y empresas que quieren reducir Excel, papel y procesos manuales.',
  },
  {
    question: '¿TransGest sustituye al Excel y a los programas antiguos de transporte?',
    answer:
      'El objetivo de TransGest es centralizar la operativa y reducir la dependencia de hojas de cálculo, carpetas, WhatsApp y herramientas desconectadas. Puede convivir con otros sistemas mediante integraciones.',
  },
  {
    question: '¿Incluye documentación digital para transporte?',
    answer:
      'TransGest está diseñado para vincular documentos a cada servicio y preparar la empresa para una gestión documental más digital, incluyendo estructuras orientadas a DeCA, eCMR, eFTI y otros requisitos del sector.',
  },
  {
    question: '¿Tiene portal cliente y app conductor?',
    answer:
      'Sí. TransGest contempla portal cliente y app conductor para mejorar la comunicación entre oficina, carretera y clientes, evitando llamadas, correos y mensajes sueltos.',
  },
  {
    question: '¿Cómo puedo ver una demo de TransGest?',
    answer:
      'Puedes solicitar una demo desde la página de solicitar demo. El equipo de Gauna Software revisará tu caso y te mostrará cómo TransGest puede encajar en tu operativa.',
  },
];

const seoSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    '@id': 'https://gauna.es/transgest/#software',
    name: 'TransGest',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    url: 'https://gauna.es/transgest/',
    description: pageDescription,
    inLanguage: 'es-ES',
    creator: {
      '@type': 'Organization',
      '@id': 'https://gauna.es/#organization',
      name: 'Gauna Software',
      url: 'https://gauna.es',
    },
    publisher: {
      '@type': 'Organization',
      '@id': 'https://gauna.es/#organization',
    },
    offers: {
      '@type': 'Offer',
      url: 'https://gauna.es/solicitar-demo/',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/PreOrder',
    },
    featureList: [
      'Gestión de servicios y cargas',
      'Gestión de tráfico',
      'Expediente digital por transporte',
      'Gestión documental para transporte',
      'Clientes, vehículos y conductores',
      'Facturación y administración',
      'Portal cliente',
      'App conductor',
      'Integraciones y API',
    ],
    audience: {
      '@type': 'Audience',
      audienceType: 'Empresas de transporte por carretera',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    '@id': 'https://gauna.es/transgest/#product',
    name: 'TransGest',
    brand: {
      '@type': 'Brand',
      name: 'Gauna Software',
    },
    description: pageDescription,
    url: 'https://gauna.es/transgest/',
    category: 'Software de gestión de transporte',
    offers: {
      '@type': 'Offer',
      url: 'https://gauna.es/solicitar-demo/',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/PreOrder',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    '@id': 'https://gauna.es/transgest/#breadcrumb',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Inicio',
        item: 'https://gauna.es/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'TransGest',
        item: 'https://gauna.es/transgest/',
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': 'https://gauna.es/transgest/#faq',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="/transgest/"
  ogImageAlt="TransGest, TMS moderno para empresas de transporte"
  schema={seoSchema}
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-20 md:pb-28 overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-900/50 via-slate-950 to-slate-950 pointer-events-none"></div>

    <div class="container-g relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/10 rounded-full mb-8">
          <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
          <span class="text-sm font-medium text-teal-50">
            TMS moderno creado desde dentro del sector transporte
          </span>
        </div>

        <h1 class="text-display-md md:text-display-lg lg:text-display-xl font-medium leading-[1.05]">
          Software de gestión de transporte para centralizar toda tu operativa.
        </h1>

        <p class="text-lg md:text-xl text-slate-300 mt-8 max-w-3xl mx-auto leading-relaxed">
          TransGest es un TMS moderno para empresas de transporte. Centraliza servicios, cargas,
          clientes, conductores, vehículos, documentación digital, facturación, fichajes, portal cliente,
          app conductor e integraciones en una sola plataforma.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/solicitar-demo/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber-500 text-slate-900 font-medium rounded-lg hover:bg-amber-400 transition-colors">
            Solicitar demo
          </a>

          <a href="https://app.gauna.es" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-medium rounded-lg hover:bg-white/15 border border-white/15 transition-colors">
            Acceso clientes
          </a>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-2 text-sm text-slate-300">
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">TMS transporte</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">Gestión de tráfico</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">Documentación digital</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">Portal cliente</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/10">App conductor</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEMAS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">El problema</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          El transporte necesita software más claro, más conectado y más realista.
        </h2>

        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          Muchas empresas siguen trabajando con información repartida entre hojas de cálculo, correos,
          WhatsApp, carpetas, programas sueltos y procesos manuales. TransGest nace para ordenar todo eso.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {problems.map((problem) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-slate-900">
              {problem.title}
            </h3>

            <p class="text-slate-600 mt-3 leading-relaxed">
              {problem.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUCIÓN -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <span class="eyebrow">La solución</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Cada servicio como expediente digital completo.
        </h2>

        <p class="text-lg text-slate-600 mt-5 max-w-3xl mx-auto leading-relaxed">
          TransGest no nace solo para apuntar cargas. El objetivo es que cada transporte tenga su propio
          expediente: datos operativos, conductor, vehículo, documentos, estados, validaciones,
          facturación, cliente y trazabilidad.
        </p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">1. Servicio</div>
            <p class="text-sm text-slate-600 mt-2">Origen, destino, cliente, fechas, carga y estado operativo.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">2. Recursos</div>
            <p class="text-sm text-slate-600 mt-2">Conductor, vehículo, documentación y datos vinculados.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">3. Documentos</div>
            <p class="text-sm text-slate-600 mt-2">DeCA, eCMR, PDFs, evidencias e historial.</p>
          </div>

          <div class="bg-slate-50 rounded-2xl p-5">
            <div class="text-sm font-semibold text-slate-900">4. Administración</div>
            <p class="text-sm text-slate-600 mt-2">Facturación, portal cliente, contabilidad e integraciones.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MÓDULOS -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">Módulos principales</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Un TMS para tráfico, administración, conductores y clientes.
        </h2>

        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          Una empresa de transporte no necesita más islas de información. Necesita una herramienta donde
          tráfico, administración, conductores y clientes trabajen sobre la misma base.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {modules.map((mod) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-5 hover:bg-white hover:border-teal-300 hover:shadow-sm transition-all">
            <h3 class="text-base font-semibold text-slate-900">
              {mod.title}
            </h3>

            <p class="text-sm text-slate-600 mt-3 leading-relaxed">
              {mod.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ESTADO DEL PRODUCTO -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <span class="eyebrow">Estado del producto</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Una plataforma avanzada para cubrir la operativa completa del transporte.
        </h2>

        <p class="text-lg text-slate-600 mt-5 max-w-3xl mx-auto leading-relaxed">
          TransGest avanza con una visión clara: centralizar la gestión operativa, documental,
          administrativa y comercial de una empresa de transporte en un único entorno.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {productStatus.map((item) => (
          <article class="bg-white border border-slate-200 rounded-2xl p-5 hover:border-teal-300 hover:shadow-sm transition-all">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="text-base font-semibold text-slate-900 leading-snug">
                {item.name}
              </h3>

              <span class={`shrink-0 text-[10px] font-semibold tracking-wide uppercase px-2.5 py-1 rounded-full border ${statusStyles[item.status] || 'bg-slate-100 text-slate-700 border-slate-200'}`}>
                {item.status}
              </span>
            </div>

            <p class="text-sm text-slate-600 leading-relaxed">
              {item.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCUMENTACIÓN Y NORMATIVA -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">Documentación y normativa</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Software preparado para la digitalización documental del transporte.
        </h2>

        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          TransGest está diseñado para trabajar con datos estructurados, documentación vinculada al servicio
          y una arquitectura orientada a DeCA, eCMR, eFTI y DIWASS, con el objetivo de avanzar hacia las
          certificaciones e integraciones necesarias del sector.
        </p>

        <div class="mt-6">
          <a href="/dcd-2026/" class="inline-flex items-center gap-2 text-sm font-medium text-teal-700 hover:text-teal-800">
            Leer guía sobre Documento de Control Digital
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {legalFeatures.map((feature) => (
          <article class="bg-slate-50 border border-slate-200 rounded-2xl p-5">
            <h3 class="text-base font-semibold text-slate-900">
              {feature.title}
            </h3>

            <p class="text-sm text-slate-600 mt-3 leading-relaxed">
              {feature.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="py-16 md:py-20 bg-slate-950 text-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow text-teal-300">Beneficios</span>

        <h2 class="text-display-sm font-medium mt-3 leading-tight">
          Menos papel, menos errores y más control.
        </h2>

        <p class="text-lg text-slate-300 mt-5 leading-relaxed">
          TransGest está pensado para empresas que quieren modernizar su gestión sin perder de vista
          la realidad diaria del transporte.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {benefits.map((benefit) => (
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="mt-1 w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>

            <p class="text-slate-200 leading-relaxed">
              {benefit}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-16 md:py-20 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="eyebrow">Preguntas frecuentes</span>

        <h2 class="text-display-sm font-medium text-slate-900 mt-3 leading-tight">
          Dudas habituales sobre TransGest.
        </h2>

        <p class="text-lg text-slate-600 mt-5 leading-relaxed">
          Respuestas rápidas para entender cómo encaja TransGest como software de gestión de transporte.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-slate-50 border border-slate-200 rounded-2xl">
            <summary class="cursor-pointer p-5 font-medium text-slate-900 flex items-start justify-between gap-4">
              <span>{faq.question}</span>

              <svg
                class="w-5 h-5 text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>

            <div class="px-5 pb-5 text-slate-700 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 md:py-24 bg-teal-900 text-white">
    <div class="container-g">
