---
import BaseLayout from '@layouts/BaseLayout.astro';
import Honeypot from '@components/Honeypot.astro';
import Turnstile from '@components/Turnstile.astro';
---

<BaseLayout
  title="Lista de espera TransGest — Acceso anticipado"
  description="Apúntate a la lista de espera de TransGest y recibe aviso en cuanto esté disponible. Condiciones exclusivas para early adopters."
>
  <section class="py-20 md:py-28">
    <div class="container-g">
      <div class="max-w-2xl mx-auto">
        <span class="eyebrow">Acceso anticipado</span>
        <h1 class="text-display-sm md:text-display-md font-medium text-slate-900 mt-4 leading-tight">
          Apúntate a la lista<br>de espera de TransGest.
        </h1>
        <p class="text-lg text-slate-600 mt-6 leading-relaxed">
          Recibirás aviso cuando abramos el acceso oficial, condiciones de early adopter
          y contacto directo con nosotros para darnos feedback durante el desarrollo.
        </p>

        <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
          <p class="text-sm text-amber-900">
            <strong>¿Quieres acceso anticipado y 2 años gratis?</strong> Aún tenemos plazas abiertas en el
            <a href="/beta-tester/" class="underline font-medium">programa Beta Tester</a> (solo 20 plazas).
          </p>
        </div>

        <div class="mt-10 bg-white rounded-xl border border-slate-200 p-6 md:p-8 shadow-sm">
          <form id="waitlist-form" class="space-y-4" data-lead-form>
            <Honeypot />
            <Turnstile formId="waitlist-form" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Nombre completo</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-slate-700 mb-1.5">Empresa</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email profesional</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
              />
            </div>

            <div>
              <label for="profile" class="block text-sm font-medium text-slate-700 mb-1.5">Tipo de perfil</label>
              <select
                id="profile"
                name="profile"
                required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
              >
                <option value="">Selecciona...</option>
                <option value="autonomo">Autónomo del transporte</option>
                <option value="pyme-pequena">Pyme con 2-5 vehículos</option>
                <option value="pyme-mediana">Pyme con 6-30 vehículos</option>
                <option value="grande">Empresa con 30+ vehículos</option>
                <option value="gestoria">Gestoría / asesoría</option>
              </select>
            </div>

            <div>
              <label for="fleet-size" class="block text-sm font-medium text-slate-700 mb-1.5">Número de vehículos (aprox.)</label>
              <input
                type="number"
                id="fleet-size"
                name="fleet-size"
                min="0"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
              />
            </div>

            <div>
              <label for="notes" class="block text-sm font-medium text-slate-700 mb-1.5">
                Cuéntanos tu principal dolor actual <span class="text-slate-400">(opcional)</span>
              </label>
              <textarea
                id="notes"
                name="notes"
                rows="3"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                placeholder="Ej: gestionar dietas de conductores, coordinar CMR con clientes..."
              ></textarea>
            </div>

            <div class="flex items-start gap-2">
              <input type="checkbox" id="consent" name="consent" required class="mt-1 rounded text-teal-600" />
              <label for="consent" class="text-xs text-slate-500 leading-relaxed">
                Acepto que mis datos sean tratados por Gauna para contactarme sobre el lanzamiento de TransGest.
                <a href="/politica-privacidad/" class="underline hover:text-teal-600">Política de privacidad</a>.
              </label>
            </div>

            <button type="submit" class="btn-primary w-full">
              Reservar mi plaza
            </button>
          </form>

          <div id="waitlist-form-success" class="hidden mt-4 p-4 bg-teal-50 border border-teal-200 rounded-lg">
            <p class="font-medium text-teal-900">¡Perfecto! Estás en la lista.</p>
            <p class="text-sm text-teal-800 mt-1">Te contactaremos antes del lanzamiento oficial.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('form[data-lead-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const formId = formEl.id;
      const success = document.getElementById(`${formId}-success`);
      if (success) {
        formEl.classList.add('hidden');
        success.classList.remove('hidden');
      }
    });
  });
</script>
