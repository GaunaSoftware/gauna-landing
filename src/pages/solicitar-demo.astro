---
import BaseLayout from '@layouts/BaseLayout.astro';
import Turnstile from '@components/Turnstile.astro';
import Honeypot from '@components/Honeypot.astro';

export const prerender = false;
---

<BaseLayout
  title="Solicitar demo de TransGest — TMS para empresas de transporte"
  description="Solicita una demo de TransGest, el TMS moderno para empresas de transporte que centraliza servicios, documentación, facturación, conductores, clientes, portal cliente e integraciones."
>
  <!-- HERO -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-slate-900 via-teal-950 to-slate-900 text-white relative overflow-hidden">
    <div class="container-g relative">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block text-xs font-medium tracking-widest uppercase text-teal-300 mb-3">
          Demo personalizada
        </span>

        <h1 class="text-display-sm md:text-display-md lg:text-display-lg font-medium mt-4 leading-[1.05] text-white">
          Solicita una demo<br />
          <span class="text-amber-400">de TransGest</span>.
        </h1>

        <p class="text-lg md:text-xl text-slate-200 mt-6 max-w-2xl mx-auto leading-relaxed">
          Cuéntanos cómo gestionas actualmente tus servicios, documentos, conductores, vehículos, clientes y facturación. Te mostraremos cómo TransGest puede ayudarte a centralizar tu operativa y trabajar con más control.
        </p>
      </div>
    </div>
  </section>

  <!-- QUÉ VERÁS EN LA DEMO -->
  <section class="py-20 md:py-24">
    <div class="container-g">
      <div class="max-w-5xl mx-auto">
        <div class="text-center max-w-2xl mx-auto">
          <span class="eyebrow">Qué veremos contigo</span>
          <h2 class="text-display-sm md:text-display-md font-medium text-slate-900 mt-4 leading-tight">
            Una demo enfocada<br />a tu operativa real.
          </h2>
          <p class="text-lg text-slate-600 mt-6">
            No queremos enseñarte una presentación genérica. Queremos entender cómo trabaja tu empresa y enseñarte dónde TransGest puede aportar valor.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-14">
          <div class="bg-white border border-slate-200 rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg bg-teal-100 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-6h6v6m2 4H7a2 2 0 01-2-2V7a2 2 0 012-2h5l2 2h3a2 2 0 012 2v10a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-medium text-slate-900 mb-3">Servicios y cargas</h3>
            <p class="text-slate-600 leading-relaxed">
              Revisaremos cómo podrías centralizar tus servicios, clientes, conductores, vehículos, estados y documentación en una sola plataforma.
            </p>
          </div>

          <div class="bg-white border border-slate-200 rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg bg-teal-100 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-medium text-slate-900 mb-3">Documentación y trazabilidad</h3>
            <p class="text-slate-600 leading-relaxed">
              Veremos cómo organizar la documentación vinculada a cada transporte, con una visión orientada a DeCA, eCMR, eFTI, DIWASS y trazabilidad documental.
            </p>
          </div>

          <div class="bg-white border border-slate-200 rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg bg-amber-100 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2" />
              </svg>
            </div>
            <h3 class="text-xl font-medium text-slate-900 mb-3">Facturación y administración</h3>
            <p class="text-slate-600 leading-relaxed">
              Analizaremos cómo conectar servicios realizados, facturas, clientes, documentación, estados administrativos y futuros módulos contables.
            </p>
          </div>

          <div class="bg-white border border-slate-200 rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg bg-teal-100 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8M8 12h8M8 17h5" />
              </svg>
            </div>
            <h3 class="text-xl font-medium text-slate-900 mb-3">App conductor y portal cliente</h3>
            <p class="text-slate-600 leading-relaxed">
              Te mostraremos cómo mejorar la comunicación entre oficina, carretera y cliente con acceso digital a información y documentación.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULARIO -->
  <section id="formulario" class="py-20 md:py-24 bg-slate-50">
    <div class="container-g">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <span class="eyebrow">Solicitar demo</span>
          <h2 class="text-display-sm md:text-display-md font-medium text-slate-900 mt-4 leading-tight">
            Cuéntanos sobre<br />tu empresa.
          </h2>
          <p class="text-slate-600 mt-6">
            Revisamos cada solicitud y contactaremos contigo para enseñarte TransGest en función de tu operativa.
          </p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 p-6 md:p-8 shadow-sm">
          <form id="beta-form" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="beta-name" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Nombre y apellidos *
                </label>
                <input type="text" id="beta-name" name="name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>

              <div>
                <label for="beta-company" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Empresa *
                </label>
                <input type="text" id="beta-company" name="company" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="beta-email" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Email profesional *
                </label>
                <input type="email" id="beta-email" name="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>

              <div>
                <label for="beta-phone" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Teléfono *
                </label>
                <input type="tel" id="beta-phone" name="phone" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>
            </div>

            <div>
              <label for="beta-profile" class="block text-sm font-medium text-slate-700 mb-1.5">
                Tipo de empresa *
              </label>
              <select id="beta-profile" name="profile" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500">
                <option value="">Selecciona...</option>
                <option value="Autónomo">Autónomo del transporte</option>
                <option value="Pyme pequeña">Pyme con 2-5 vehículos</option>
                <option value="Pyme mediana">Pyme con 6-30 vehículos</option>
                <option value="Empresa grande">Empresa con 30+ vehículos</option>
                <option value="Operador logístico">Operador logístico</option>
                <option value="Gestoría">Gestoría / asesoría</option>
              </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="beta-fleet" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Nº de vehículos
                </label>
                <input type="number" id="beta-fleet" name="fleet" min="0" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>

              <div>
                <label for="beta-tools" class="block text-sm font-medium text-slate-700 mb-1.5">
                  ¿Qué usáis ahora?
                </label>
                <input type="text" id="beta-tools" name="tools" placeholder="Excel, otro TMS, papel, ERP..." class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" />
              </div>
            </div>

            <div>
              <label for="beta-why" class="block text-sm font-medium text-slate-700 mb-1.5">
                ¿Qué problema quieres resolver con TransGest? *
              </label>
              <textarea id="beta-why" name="why" rows="4" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="Ej: documentos por WhatsApp, cargas en Excel, facturación manual, clientes llamando para pedir documentación..."></textarea>
            </div>

            <Honeypot />
            <Turnstile formId="beta-form" />

            <div class="flex items-start gap-2">
              <input type="checkbox" id="beta-consent" name="consent" required class="mt-1 rounded text-teal-600" />
              <label for="beta-consent" class="text-xs text-slate-500 leading-relaxed">
                Acepto que Gauna trate mis datos para evaluar mi solicitud y contactarme sobre TransGest.
                <a href="/politica-privacidad/" class="underline hover:text-teal-600">Política de privacidad</a>.
              </label>
            </div>

            <div id="beta-form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-sm text-red-900" data-error-message>
                Ha ocurrido un error. Intenta de nuevo o escríbenos a <a href="mailto:hola@gauna.es" class="underline">hola@gauna.es</a>.
              </p>
            </div>

            <button type="submit" class="btn-primary w-full text-base py-4" id="beta-submit-btn">
              <span data-btn-text>Solicitar demo</span>
              <span data-btn-loading class="hidden">Enviando...</span>
            </button>
          </form>

          <div id="beta-form-success" class="hidden mt-4 p-6 bg-teal-50 border border-teal-200 rounded-lg">
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-teal-900">Solicitud recibida</p>
                <p class="text-sm text-teal-800 mt-1">
                  Gracias por solicitar una demo de TransGest. Revisaremos tu solicitud y contactaremos contigo por email o teléfono.
                </p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA SECUNDARIO -->
  <section class="py-20 md:py-24 bg-white">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">TransGest</span>
        <h2 class="text-display-sm md:text-display-md font-medium text-slate-900 mt-4 leading-tight">
          Un TMS moderno para trabajar con menos papel, menos errores y más control.
        </h2>
        <p class="text-lg text-slate-600 mt-6 leading-relaxed">
          TransGest centraliza servicios, documentación, clientes, conductores, vehículos, facturación, fichajes, portal de cliente e integraciones en una plataforma pensada desde dentro del sector transporte.
        </p>

        <div class="mt-10">
          <a href="/transgest/" class="btn-secondary">
            Ver página de TransGest
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('beta-form') as HTMLFormElement | null;
  const successBox = document.getElementById('beta-form-success');
  const errorBox = document.getElementById('beta-form-error');
  const errorMsg = document.querySelector('[data-error-message]');
  const btn = document.getElementById('beta-submit-btn') as HTMLButtonElement | null;
  const btnText = document.querySelector('[data-btn-text]');
  const btnLoading = document.querySelector('[data-btn-loading]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form || !btn) return;

    btn.disabled = true;
    btnText?.classList.add('hidden');
    btnLoading?.classList.remove('hidden');
    errorBox?.classList.add('hidden');

    const formData = new FormData(form);

    const payload = {
      name: formData.get('name'),
      company: formData.get('company'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      profile: formData.get('profile'),
      fleet: formData.get('fleet'),
      tools: formData.get('tools'),
      why: formData.get('why'),
      website: formData.get('website'),
      turnstileToken: formData.get('turnstileToken'),
      startedAt: formData.get('startedAt'),
      source: 'solicitar-demo',
    };

    try {
      const response = await fetch('/api/demo-signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Error del servidor');
      }

      form.classList.add('hidden');
      successBox?.classList.remove('hidden');
      successBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch (err: any) {
      if (errorMsg) {
        errorMsg.textContent = `No hemos podido enviar tu solicitud: ${err.message}. Puedes escribirnos directamente a hola@gauna.es.`;
      }

      errorBox?.classList.remove('hidden');
      btn.disabled = false;
      btnText?.classList.remove('hidden');
      btnLoading?.classList.add('hidden');
    }
  });
</script>
