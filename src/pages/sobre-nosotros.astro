
---
import BaseLayout from '@layouts/BaseLayout.astro';

export const prerender = true;

const valores = [
  {
    titulo: 'Conocimiento del sector',
    descripcion:
      'Construimos herramientas para transporte desde problemas reales: tráfico, documentación, clientes, conductores, vehículos, facturación y control diario.',
  },
  {
    titulo: 'Modernidad',
    descripcion:
      'Queremos llevar al sector una experiencia de software más clara, rápida y actual, apoyándonos en automatización, datos e inteligencia operativa.',
  },
  {
    titulo: 'Cercanía',
    descripcion:
      'Somos un equipo pequeño, directo y accesible. Hablamos con las empresas, escuchamos su operativa y convertimos sus necesidades en producto.',
  },
  {
    titulo: 'Transparencia',
    descripcion:
      'Preferimos explicar claramente qué está disponible, qué está en desarrollo y hacia dónde evoluciona el producto antes que vender humo.',
  },
];

const formasTrabajo = [
  {
    titulo: 'Escuchamos la operativa real',
    descripcion:
      'No diseñamos desde una teoría. Analizamos cómo trabaja una empresa de transporte en su día a día: llamadas, WhatsApp, Excel, documentos, facturas, vehículos y conductores.',
  },
  {
    titulo: 'Convertimos problemas en módulos',
    descripcion:
      'Cada parte de TransGest nace de una necesidad concreta: ordenar servicios, controlar documentación, mejorar la trazabilidad, reducir tareas manuales y dar más visibilidad a gerencia.',
  },
  {
    titulo: 'Construimos con visión de futuro',
    descripcion:
      'El transporte avanza hacia más digitalización, interoperabilidad y datos estructurados. Por eso diseñamos herramientas preparadas para evolucionar con el sector.',
  },
];

const productos = [
  {
    nombre: 'TransGest',
    estado: 'Software en desarrollo activo',
    descripcion:
      'TMS moderno para empresas de transporte que centraliza servicios, cargas, clientes, conductores, vehículos, documentación, facturación, fichajes, portal cliente e integraciones.',
    href: '/transgest/',
    cta: 'Conocer TransGest',
  },
];
---

<BaseLayout
  title="Sobre nosotros — Gauna Software"
  description="Gauna Software es un estudio especializado en crear herramientas digitales para empresas de transporte. Conoce nuestra visión, forma de trabajar y el origen de TransGest."
>
  <!-- HERO INTRO -->
  <section class="pt-16 md:pt-24 pb-12 md:pb-16">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Sobre nosotros</span>

        <h1 class="text-3xl md:text-5xl lg:text-6xl font-medium tracking-tight text-slate-900 mt-4 leading-[1.1]">
          Creamos software para modernizar el transporte.
        </h1>

        <p class="text-lg md:text-xl text-slate-600 mt-6 leading-relaxed">
          Gauna Software es un estudio especializado en crear herramientas digitales para empresas de transporte.
          Nuestro objetivo es ayudar al sector a reducir papel, automatizar tareas, centralizar información y trabajar con más control.
        </p>
      </div>
    </div>
  </section>

  <!-- POR QUÉ NACE GAUNA -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Por qué nace Gauna</span>

        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-slate-900 mt-4 leading-tight">
          El transporte necesitaba<br />software más claro, conectado y actual.
        </h2>

        <div class="mt-8 space-y-5 text-lg text-slate-700 leading-relaxed">
          <p>
            Muchas empresas de transporte siguen trabajando con información repartida entre Excel, WhatsApp,
            correos, carpetas, software antiguo y documentos que no siempre están conectados entre sí.
          </p>

          <p>
            Eso provoca pérdida de tiempo, duplicidad de tareas, falta de trazabilidad y una visión incompleta
            de lo que ocurre en tráfico, administración, documentación, facturación y gerencia.
          </p>

          <p>
            Gauna Software nace para construir herramientas especializadas que entiendan esa realidad.
            TransGest es nuestro primer gran producto: un TMS moderno pensado para centralizar la operativa
            diaria de una empresa de transporte y prepararla para una gestión más digital.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALORES -->
  <section class="py-20 md:py-24">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Valores</span>

        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-slate-900 mt-4 leading-tight">
          Cuatro principios que guían cada decisión de producto.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12 max-w-4xl mx-auto">
        {valores.map((valor) => (
          <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-teal-300 hover:shadow-sm transition-all">
            <h3 class="text-lg font-medium tracking-tight text-slate-900 mb-2">
              {valor.titulo}
            </h3>

            <p class="text-slate-600 leading-relaxed">
              {valor.descripcion}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CÓMO TRABAJAMOS -->
  <section class="py-16 md:py-20 bg-slate-50">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Cómo trabajamos</span>

        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-slate-900 mt-4 leading-tight">
          Producto, transporte<br />y tecnología trabajando juntos.
        </h2>

        <p class="text-lg text-slate-600 mt-6 leading-relaxed">
          No queremos crear una herramienta genérica más. Queremos construir software útil para empresas que viven el transporte cada día.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12 max-w-6xl mx-auto">
        {formasTrabajo.map((item) => (
          <div class="bg-white border border-slate-200 rounded-xl p-6">
            <h3 class="text-lg font-medium tracking-tight text-slate-900 mb-3">
              {item.titulo}
            </h3>

            <p class="text-slate-600 leading-relaxed">
              {item.descripcion}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NUESTROS PRODUCTOS -->
  <section class="py-20 md:py-24">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Nuestros productos</span>

        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-slate-900 mt-4 leading-tight">
          Empezamos por TransGest.<br />El ecosistema seguirá creciendo.
        </h2>

        <p class="text-lg text-slate-600 mt-6 leading-relaxed">
          Nuestra visión es crear un conjunto de herramientas digitales especializadas para transporte,
          conectadas entre sí y pensadas para resolver problemas reales del sector.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12 max-w-4xl mx-auto">
        {productos.map((producto) => (
          <a
            href={producto.href}
            class="group bg-white border border-slate-200 rounded-xl p-8 hover:border-teal-300 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between gap-3 mb-4">
              <span class="text-xs font-medium tracking-wider uppercase text-teal-800 bg-teal-100 px-2.5 py-1 rounded-full">
                {producto.estado}
              </span>
            </div>

            <h3 class="text-2xl font-medium tracking-tight text-slate-900 mb-3">
              {producto.nombre}
            </h3>

            <p class="text-slate-600 leading-relaxed mb-5">
              {producto.descripcion}
            </p>

            <span class="inline-flex items-center gap-1 text-sm font-medium text-teal-700 group-hover:gap-2 transition-all">
              {producto.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}

        <div class="bg-slate-50 border border-slate-200 rounded-xl p-8">
          <div class="flex items-start justify-between gap-3 mb-4">
            <span class="text-xs font-medium tracking-wider uppercase text-slate-500 bg-slate-200 px-2.5 py-1 rounded-full">
              Próximamente
            </span>
          </div>

          <h3 class="text-2xl font-medium tracking-tight text-slate-700 mb-3">
            Más herramientas
          </h3>

          <p class="text-slate-500 leading-relaxed">
            Estamos trabajando en nuevas soluciones para cubrir más áreas del sector:
            documentación, análisis, automatización, integraciones y procesos específicos del transporte.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-16 md:py-20 bg-teal-950 text-white">
    <div class="container-g">
      <div class="max-w-2xl mx-auto text-center">
        <span class="inline-block text-xs font-medium tracking-widest uppercase text-teal-300 mb-4">
          TransGest
        </span>

        <h2 class="text-3xl md:text-4xl font-medium tracking-tight leading-tight">
          ¿Quieres ver cómo TransGest puede encajar en tu empresa?
        </h2>

        <p class="text-lg text-slate-200 mt-6 leading-relaxed">
          Solicita una demo y cuéntanos cómo gestionas actualmente tus servicios,
          documentación, clientes, vehículos, conductores y facturación.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/solicitar-demo/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-amber-500 text-slate-950 font-medium rounded-lg hover:bg-amber-400 transition-colors"
          >
            Solicitar demo
          </a>

          <a
            href="/contacto/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 text-white font-medium rounded-lg hover:bg-white/15 border border-white/20 transition-colors"
          >
            Hablar con nosotros
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

