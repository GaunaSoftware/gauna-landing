---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = {
  normativa: { label: 'Normativa', color: 'bg-amber-100 text-amber-800' },
  gestion: { label: 'Gestión', color: 'bg-teal-100 text-teal-800' },
  nominas: { label: 'Nóminas', color: 'bg-slate-100 text-slate-800' },
  tecnologia: { label: 'Tecnología', color: 'bg-blue-100 text-blue-800' },
};
---

<BaseLayout
  title="Blog | Gauna — Actualidad y análisis del transporte"
  description="Artículos sobre normativa 2026, gestión de flotas, nóminas del transporte y digitalización. Construido por profesionales del sector."
>
  <section class="py-16 md:py-20 border-b border-slate-100">
    <div class="container-g">
      <div class="max-w-3xl mx-auto text-center">
        <span class="eyebrow">Blog</span>
        <h1 class="text-display-sm md:text-display-md font-medium text-slate-900 mt-4 leading-tight">
          Actualidad del transporte.
        </h1>
        <p class="text-lg text-slate-600 mt-6 leading-relaxed">
          Análisis, guías y novedades sobre normativa, gestión y tecnología en el transporte por carretera. Escrito por gente del sector.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container-g">
      {posts.length === 0 ? (
        <div class="max-w-2xl mx-auto text-center py-20">
          <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h2 class="text-2xl font-medium text-slate-900 mb-4">Publicamos pronto el primer artículo</h2>
          <p class="text-slate-600 mb-8">
            Estamos preparando contenido profundo sobre el DCD, nóminas de conductores y otros temas clave del sector.
            Suscríbete para recibir los nuevos artículos.
          </p>
          <a href="/dcd-2026/#lead-form" class="btn-primary">
            Recibir avisos por email
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {posts.map((post) => {
            const cat = categories[post.data.category];
            return (
              <a href={`/blog/${post.slug}/`} class="group">
                <article class="h-full flex flex-col bg-white rounded-xl border border-slate-200 overflow-hidden hover:border-teal-300 hover:shadow-md transition-all">
                  <div class="p-6 flex-1 flex flex-col">
                    <div class="flex items-center gap-2 mb-4">
                      <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-medium ${cat.color}`}>
                        {cat.label}
                      </span>
                      <time class="text-xs text-slate-500" datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                      </time>
                    </div>
                    <h2 class="text-xl font-medium text-slate-900 group-hover:text-teal-600 transition-colors leading-tight mb-3">
                      {post.data.title}
                    </h2>
                    <p class="text-slate-600 leading-relaxed flex-1">
                      {post.data.description}
                    </p>
                    <div class="mt-4 text-sm text-slate-500">
                      {post.data.author}
                    </div>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
