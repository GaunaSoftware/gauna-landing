---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const footerCols = [
  {
    title: 'Producto',
    links: [
      { href: '/transgest/', label: 'TransGest' },
      { href: '/beta-tester/', label: 'Programa Beta' },
      { href: '/transgest/demo/', label: 'Lista de espera' },
      { href: '/transgest/precios/', label: 'Precios' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { href: '/dcd-2026/', label: 'Guía DCD 2026' },
      { href: '/dcd-2026/kit/', label: 'Kit DCD Premium' },
      { href: '/blog/', label: 'Blog' },
      { href: '/recursos/', label: 'Plantillas y descargas' },
    ],
  },
  {
    title: 'Empresa',
    links: [
      { href: '/sobre-nosotros/', label: 'Sobre nosotros' },
      { href: '/contacto/', label: 'Contacto' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/politica-privacidad/', label: 'Política de privacidad' },
      { href: '/aviso-legal/', label: 'Aviso legal' },
      { href: '/politica-cookies/', label: 'Política de cookies' },
    ],
  },
];
---

<footer class="bg-slate-900 text-slate-300 mt-24">
  <div class="container-g py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <Logo variant="compact" theme="dark" class="h-9 w-auto mb-4" />
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Software para el transporte, construido por y para profesionales del sector.
        </p>
        <p class="text-sm text-slate-500 mt-6">
          Elche, Alicante · España
        </p>
      </div>

      <div class="md:col-span-8 grid grid-cols-2 sm:grid-cols-4 gap-8">
        {footerCols.map((col) => (
          <div>
            <h3 class="text-sm font-medium text-white mb-4">{col.title}</h3>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 hover:text-teal-400 transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        © {year} Gauna. Todos los derechos reservados.
      </p>
      <p class="text-xs text-slate-500">
        Hecho en España con criterio.
      </p>
    </div>
  </div>
</footer>
